# devkitPro build artifacts
build/
*.3dsx
*.elf
*.smdh
*.cia
*.map
*.lst
banner.bnr

# Generated graphics (built from gfx/*.t3s)
romfs/gfx/*.t3x
*.t3x

# Generated audio (copied from assets/ into romfs by the Makefile)
romfs/audio/

# CIA packaging tools (fetch these yourself - see README "Build the CIA")
tools/cia/

# Companion website (kept out of the game repo)
SITE_exclude/

# Discord bot (kept out of the game repo - holds the bot token)
BOT_exclude/

# Admin panel (kept out of the game repo - moderator tooling / KV ids)
ADMIN_exclude/

# Android app (kept out of the game repo)
Android_EXCLUDE/

# Catch-all: any folder whose name ends in _EXCLUDE / _exclude
*_EXCLUDE/
*_exclude/

# Host test build
tests/build/
tests/petpal_tests
tests/petpal_tests.exe

# Local save data (when testing on host)
save.bin
save.bak
backups/

# Editor / tooling / OS cruft
.claude/
.vscode/
.DS_Store
Thumbs.db

# Local tooling caches (wrangler state, python bytecode)
.wrangler/
__pycache__/
